# Copy this file to .env and fill in your real key.
# .env is already in .gitignore — never commit your real key.
# If a key has ever been pasted into a chat, doc, or screenshot, treat it as
# burned and rotate it in Google AI Studio / Cloud Console before the event.

GEMINI_API_KEY=your-key-here

# --- Multi-key rotation (optional) ---
# If you're juggling multiple Gemini keys to avoid hitting one key's quota
# mid-demo, set these instead of (or in addition to) GEMINI_API_KEY above.
# config.py will try them in order and fall through on quota/rate errors.
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=

# Verified correct model ID strings (confirmed against ai.google.dev as of
# this week — these are the literal strings the SDK expects, not marketing
# names):
#   gemini-3.5-flash   <- GA, stable, fast. Good default for the build.
#   gemini-3.1-pro-preview  <- strongest reasoning in your lineup; use this
#                              if you want Gemini to deep-think an
#                              architecture/edge-case pass on a gnarly
#                              problem statement before you start coding.
#                              It's a preview model, not GA — has no
#                              confirmed downside for a few hours of use,
#                              just don't be surprised if behavior shifts
#                              release to release.
#   gemini-2.5-pro     <- older but fully stable non-preview fallback if
#                              you want Pro-tier reasoning without
#                              preview-model risk.
GEMINI_MODEL=gemini-3.5-flash

# Optional second model just for an upfront "think hard about the
# architecture and edge cases" pass before you start building — only
# relevant if you adopt the two-model strategy described in FAQ.md.
GEMINI_ARCHITECT_MODEL=gemini-3.1-pro-preview
