# ============================================
# PromptWars .gitignore — cross-language
# Keeps repo small (in-person cap: <1MB, virtual cap: <10MB)
# ============================================

# --- Secrets (NEVER commit these) ---
.env
.env.local
.env.*.local
*.key
*.pem
secrets.json
credentials.json
service-account*.json

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/
.ipynb_checkpoints/

# --- Node / React / JS / TS ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.next/
.nuxt/
out/
build/
dist/
.cache/
.parcel-cache/
*.tsbuildinfo

# --- Java / Kotlin ---
*.class
*.jar
*.war
target/
.gradle/
build/

# --- Go ---
*.exe
*.test
vendor/

# --- Docker ---
*.log

# --- OS noise ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo

# --- Large/binary assets that blow the size cap ---
*.mp4
*.mov
*.zip
*.tar.gz
*.psd
*.sketch
*.mp3
*.wav

# --- Misc ---
.DS_Store
coverage/
*.log
